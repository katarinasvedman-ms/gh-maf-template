{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "restore",
      "type": "shell",
      "command": "dotnet",
      "args": ["restore"],
      "group": "build"
    },
    {
      "label": "build",
      "type": "shell",
      "command": "dotnet",
      "args": ["build", "--configuration", "Release"],
      "group": "build",
      "dependsOn": ["restore"]
    },
    {
      "label": "test",
      "type": "shell",
      "command": "dotnet",
      "args": ["test", "--configuration", "Release"],
      "group": "test",
      "dependsOn": ["build"]
    },
    {
      "label": "run-host",
      "type": "shell",
      "command": "dotnet",
      "args": ["run", "--project", "src/Template.Host/Template.Host.csproj", "--configuration", "Release"]
    },
    {
      "label": "bootstrap-rename",
      "type": "shell",
      "command": "pwsh",
      "args": ["-NoProfile", "-File", "scripts/bootstrap-rename.ps1", "-ProjectName", "Contoso.Agent"]
    }
  ]
}
